# ─── Secrets — NEVER commit these ───────────────────────────
# Your real bot token lives in .env on your PC. If this ever got
# committed to the public repo, anyone could hijack your bot.
.env
.env.*
!.env.example

# ─── Python virtual environment ─────────────────────────────
venv/
.venv/

# ─── Python cache / compiled files ──────────────────────────
__pycache__/
*.pyc

# ─── Bot data ───────────────────────────────────────────────
# Created at runtime on the PC that runs the bot. Holds user
# data and is only meaningful on that machine, so we don't
# track it in the public repo.
data.json
data/
