# This is a TEMPLATE. It is safe to commit because it has no real secret.
#
# On your PC: copy this file to a new file named ".env" (same folder),
# then paste your real Discord bot token after the = sign.
#
# The real ".env" is listed in .gitignore, so git will ignore it and it
# will never be pushed to the public repo. Never share or commit the token.

DISCORD_TOKEN=put-your-real-token-here

# Comma-separated Discord server (guild) IDs to register slash commands in.
# Commands appear INSTANTLY in the listed servers — great for your test server
# and Poogie Bois, e.g.  GUILD_IDS=111111111111111111,222222222222222222
# Leave blank to register globally instead (works everywhere the bot is, but
# can take up to ~1 hour to show up).
# Get an ID: Discord > Settings > Advanced > Developer Mode, then right-click
# the server's icon > Copy Server ID.
GUILD_IDS=
